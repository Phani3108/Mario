# Production build env — applies when deployed to Vercel or any non-local
# host. Turns on the in-browser demo shim so the field PWA shows seeded
# Hyderabad data with zero backend required. Override on a deployed env
# (e.g. real API at https://api.example.com) by setting VITE_API_URL and
# VITE_DEMO=false.
VITE_DEMO=true
VITE_API_URL=http://localhost:4000
