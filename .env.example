# SiteFlow local dev env — DO NOT use any of these values outside docker-compose
DATABASE_URL=postgres://siteflow:siteflow@localhost:5433/siteflow
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible) — local dev only
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=ap-south-1
S3_BUCKET=siteflow-evidence
S3_ACCESS_KEY=siteflow
S3_SECRET_KEY=siteflowsecret
S3_FORCE_PATH_STYLE=true

# JWT — dev only, rotate before any non-local use
JWT_SECRET=dev-only-change-me-d4f8c7b2a1e9f6d3c5a7b9e1f3d5c7a9
JWT_ISSUER=siteflow-dev

# API
API_PORT=4000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5174

# Geofence default radius (meters) — override per site in DB
GEOFENCE_RADIUS_M=150
